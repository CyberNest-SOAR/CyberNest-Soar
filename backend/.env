DATABASE_URL="postgresql://postgres:postgres@localhost:5433/soar_db"
GOOGLE_CLIENT_SECRET_FILE="client_secret/client_secret.json"
GMAIL_SYNC_FOLDER="INBOX"
TOKEN_DIRECTORY="token_files"
# Use artifact paths relative to the `backend/` package root (this .env lives in `backend/`).
# `artifacts/...` points to `backend/artifacts/...` where the joblib files live.
MODEL_ARTIFACT_PATH="artifacts/phishing_model.joblib"
VECTORIZER_ARTIFACT_PATH="artifacts/tfidf_vectorizer.joblib"
TRAINING_DATA_PATH="data/data.csv"