alert http any any -> $HOME_NET any (msg:"PHISHING - Fake Banking Portal Access"; flow:established,to_server; content:"login"; pcre:"/bank|secure|account|update|verify/i"; classtype:web-application-attack; sid:1000003; rev:1;)
alert http any any -> $HOME_NET any (msg:"PHISHING - Credential Submission Detected"; flow:established,to_server; content:"POST"; http_method; pcre:"/username=|email=/i"; content:"password="; http_client_body; classtype:web-application-attack; sid:1000004; rev:1;)
